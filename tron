#!/usr/bin/env bash
# tron — the operator entrypoint. Two commands:
#
#   tron seeder    seed TRON into a target project (interactive; run from the project root)
#   tron start     wake TRON: bootup (start point, worker count) then the live console
#
# Everything else is internal — the heartbeat (the WAKE daemon), recovery, and validation
# run themselves. Those verbs exist below but are not the operator surface.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TRON_DIR="$SCRIPT_DIR"
export TRON_DIR
ENGINE="$TRON_DIR/engine/engine.py"
# The worker-agent runtime, resolved once. Override with TRON_RUNTIME; the literal
# default is the only place the host runtime is named (never in operator-facing copy).
RUNTIME="${TRON_RUNTIME:-claude}"

usage() {
  cat <<'EOF'
TRON — a deterministic supervisor that builds software from specs.

  tron seeder    seed TRON into a target project (run from the project root)
  tron start     wake TRON: bootup, then the live console

Inside `tron start`: type to talk to TRON; `status` / `pipeline` to look; `stop` to end.
EOF
}

cmd="${1:-}"; [ $# -gt 0 ] && shift || true
case "$cmd" in
  seeder)
    # Interactive seeding: drive the agent runtime through the seed protocol.
    # The protocol ships only with the canon clone; a seeded instance carries no
    # tron-seed.md. Fail clearly rather than asking the agent to read a missing file.
    [ -f "$TRON_DIR/tron-seed.md" ] || {
      echo "tron seeder: run this from a TRON canon clone (no tron-seed.md here — this looks like a seeded instance)." >&2
      exit 5
    }
    command -v "$RUNTIME" >/dev/null 2>&1 || { echo "tron seeder: the agent runtime is not on PATH" >&2; exit 4; }
    exec "$RUNTIME" "Read $TRON_DIR/tron-seed.md in full and seed TRON into this project, following it step by step."
    ;;
  start)
    exec python3 "$ENGINE" console "$@"
    ;;
  tick|wake|stop|recover|validate|doctor|msg)   # internal: daemon / automatic / dev
    exec python3 "$ENGINE" "$cmd" "$@"
    ;;
  ""|help|-h|--help)
    usage
    ;;
  *)
    echo "tron: unknown command '$cmd' — try: tron seeder | tron start" >&2
    exit 2
    ;;
esac
