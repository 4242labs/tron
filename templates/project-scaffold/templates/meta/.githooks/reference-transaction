#!/usr/bin/env bash
# reference-transaction — the trunk-scoped mechanical backstop (ADR-0002 D2, block
# 01-32 T3). Scoped to refs/heads/<main> ONLY (unscoped would tax every fleet
# branch write, per the ADR): refuses a trunk ref-update unless a LIVE grant's
# patch-id matches the exact <old>..<new> range the transaction carries. The happy
# path (land.sh's own advance) always passes by construction, because THIS hook
# checks BEFORE land.sh consumes the grant.
#
# git contract: `githooks/reference-transaction` is invoked as
# `reference-transaction <state>` (state one of prepared|committed|aborted), with
# stdin lines "<old-value> SP <new-value> SP <ref-name>", one per ref the
# transaction touches. Only `prepared` can still abort the transaction (a nonzero
# exit at committed/aborted is a no-op, per git's own hook contract) — this hook is
# therefore a no-op at any state other than `prepared`.
#
# Requires git >= 2.26 (the reference-transaction hook type doesn't exist before
# that) — probed at seat by the engine (trunk.git_version); where unavailable (or
# this hook simply isn't installed — core.hooksPath not pointed here), the engine
# degrades LOUDLY to detect-only (AC-8): prevention is best-effort, detection
# (next-tick observation) still catches an out-of-gate land regardless.
set -euo pipefail

STATE="${1:-}"
[ "$STATE" = "prepared" ] || exit 0

MAIN_BRANCH="${LAND_MAIN_BRANCH:-main}"
# ADR-0003 D-G (02-12 T1): worktree-safe root — --show-toplevel resolves the current
# worktree, not the shared project root the grants dir lives under.
REPO_ROOT="$(cd "$(git rev-parse --git-common-dir)/.." && pwd)"
GRANTS_DIR="${LAND_GRANTS_DIR:-$REPO_ROOT/meta/agents/tron/grants}"
MAIN_REF="refs/heads/$MAIN_BRANCH"

while read -r old new refname; do
  [ "$refname" = "$MAIN_REF" ] || continue   # every other ref: fleet workspace, not this hook's job

  RANGE_PID="$(git -C "$REPO_ROOT" diff "${old}..${new}" 2>/dev/null | git -C "$REPO_ROOT" patch-id --stable 2>/dev/null | awk '{print $1}')"
  if [ -z "$RANGE_PID" ]; then
    # Fail-closed rider: an empty/unresolvable patch-id for the range itself is
    # never a free pass either — refuse rather than guess.
    echo "reference-transaction: refusing $refname $old..$new — the range's own patch-id is empty/unresolvable (fail-closed, ADR-0002 D2)" >&2
    exit 1
  fi

  MATCHED=""
  if [ -d "$GRANTS_DIR" ]; then
    for gf in "$GRANTS_DIR"/*.grant; do
      [ -e "$gf" ] || continue
      GPID="$(awk -F= '$1=="patch_id"{v=substr($0,10)} END{print v}' "$gf")"
      if [ -n "$GPID" ] && [ "$GPID" = "$RANGE_PID" ]; then
        MATCHED="$gf"
        break
      fi
    done
  fi

  if [ -z "$MATCHED" ]; then
    echo "reference-transaction: refusing $refname $old..$new — no LIVE grant's patch-id matches this range (ADR-0002 D2: land.sh is the only sanctioned path, and this range wasn't authorized)" >&2
    exit 1
  fi
done

exit 0
