# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── AI (LiteLLM proxy) ────────────────────────────────────────────────────────
LITELLM_API_KEY=
LITELLM_BASE_URL=

# ── Auth (Google OAuth) ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Vercel ────────────────────────────────────────────────────────────────────
# Set automatically by Vercel — do not set manually
# VERCEL_ENV=
# VERCEL_URL=

# ── Error Monitoring (Sentry) — production only ───────────────────────────────
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN — set as GitHub secret for CI source map uploads, not here

# ── Analytics (Matomo) ────────────────────────────────────────────────────────
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=

# ── Email (Brevo) — production only ──────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# ── Payments (Polar) ──────────────────────────────────────────────────────────
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=

# ── Support (Plain) ───────────────────────────────────────────────────────────
PLAIN_API_KEY=

# ── Affiliates (FirstPromoter) ────────────────────────────────────────────────
NEXT_PUBLIC_FP_ACCOUNT_ID=
FP_API_KEY=

# ── Slack Webhooks ────────────────────────────────────────────────────────────
SLACK_WEBHOOK_FINANCIAL=
SLACK_WEBHOOK_AFFILIATES=
SLACK_WEBHOOK_DEPLOYS_STAGING=
SLACK_WEBHOOK_DEPLOYS_PROD=
SLACK_WEBHOOK_DIGEST=
SLACK_WEBHOOK_INFRA=

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=

# ── Add project-specific vars below ──────────────────────────────────────────
